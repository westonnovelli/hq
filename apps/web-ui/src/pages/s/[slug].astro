---
import SnippetViewer from '../../components/SnippetViewer.astro';

const { slug } = Astro.params;
const API_URL = import.meta.env.PUBLIC_SNIPPETS_API_URL || 'https://api.weston.novelli.dev';

// For GitHub Pages, we need to generate at least one static HTML file
// We'll use client-side routing to extract the slug from the URL
export async function getStaticPaths() {
    // Generate a catch-all route - this will create /s/index.html
    // The SnippetViewer component will extract the actual slug from the URL client-side
    return [{ params: { slug: 'index' } }];
}
---

<SnippetViewer slug={slug || ''} apiUrl={API_URL} />
