---
import SnippetViewer from '../../components/SnippetViewer.astro';

const { slug } = Astro.params;
const API_URL = import.meta.env.PUBLIC_SNIPPETS_API_URL || 'https://api.weston.novelli.dev';

// For static output, we need getStaticPaths even if we return empty array
// All /s/* routes will be handled by the 404 page
export async function getStaticPaths() {
    return [];
}
---

<SnippetViewer slug={slug || ''} apiUrl={API_URL} />
