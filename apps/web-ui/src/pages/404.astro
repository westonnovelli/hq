---
import PostHogLayout from '../components/scaffold/PostHogLayout.astro';
import MinimalLayout from "../components/scaffold/minimal-layout.astro";
import SnippetViewer from '../components/SnippetViewer.astro';

// Extract the current path from the request
const url = Astro.url;
const pathname = url.pathname;

// Check if this is a /s/ route
const sRouteMatch = pathname.match(/^\/s\/(.+)$/);
const slug = sRouteMatch ? sRouteMatch[1] : null;
const API_URL = import.meta.env.PUBLIC_SNIPPETS_API_URL || 'https://api.weston.novelli.dev';
---

{slug ? (
    <!-- This is a /s/ route - render the snippet page -->
    <SnippetViewer slug={slug} apiUrl={API_URL} />
) : (
    <!-- Regular 404 page -->
    <PostHogLayout>
        <MinimalLayout title="Page Not Found">
            <div class="min-h-screen flex items-center justify-center px-4 py-16">
                <div class="text-center">
                    <div class="text-6xl mb-4">&#x1F50D;</div>
                    <h1 class="text-3xl font-bold text-white mb-4">Page Not Found</h1>
                    <p class="text-white/90 text-lg mb-6">The page you're looking for doesn't exist.</p>
                    <a href="/" class="inline-block px-6 py-3 bg-white/20 hover:bg-white/30 text-white rounded-lg transition-colors">
                        Go Home
                    </a>
                </div>
            </div>
        </MinimalLayout>
    </PostHogLayout>
)}

